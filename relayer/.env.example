# DarkDrop V4 Relayer — example environment configuration

# Solana
RPC_URL=https://api.devnet.solana.com
RELAYER_KEYPAIR=~/.config/solana/relayer.json
SOL_PROGRAM_ID=GSig1QYVwPVhHF6oVEwhadAwdWjTqtq6H5cSMEkfAgkU
TEST_PROGRAM_ID=8b8JX1nhcG5UryRUE6Zm85LLcTA6PjquEkUVwWRV6Rrn

# Fee policy
FEE_RATE_BPS=50

# Network exposure
CORS_ORIGIN=http://localhost:3000
PORT=3001

# Claim envelope
MAX_CLAIM=100000000000

# Compute-unit budgets per relay endpoint. Bump if a Solana runtime
# repricing or a groth16-solana upgrade pushes verification cost over the
# default. Safe to leave unset; defaults match the previously hardcoded values.
V1_CLAIM_CU=200000
V2_CREDIT_CLAIM_CU=400000
V2_CREDIT_SPL_CLAIM_CU=400000
V3_POOL_CLAIM_CU=400000
